{
  "rules": {
    "basic.AssertWithinFinallyBlock": "error",
    "basic.AssignmentInConditional": "warn",
    "basic.BigDecimalInstantiation": "warn",
    "basic.BitwiseOperatorInConditional": "warn",
    "basic.BooleanGetBoolean": "warn",
    "basic.BrokenNullCheck": "error",
    "basic.BrokenOddnessCheck": "error",
    "basic.ClassForName": "warn",
    "basic.ComparisonOfTwoConstants": "error",
    "basic.ComparisonWithSelf": "error",
    "basic.ConstantAssertExpression": "error",
    "basic.ConstantTernaryExpression": "warn",
    "basic.ConstantIfExpression": "error",
    "basic.DeadCode": "error",
    "basic.DoubleNegative": "warn",
    "basic.DuplicateCaseStatement": "error",
    "basic.DuplicateMapKey": "error",
    "basic.DuplicateSetValue": "error",
    "basic.EmptyCatchBlock": "error",
    "basic.EmptyClass": "warn",
    "basic.EmptyElseBlock": "warn",
    "basic.EmptyFinallyBlock": "warn",
    "basic.EmptyForStatement": "warn",
    "basic.EmptyIfStatement": "warn",
    "basic.EmptySwitchStatement": "warn",
    "basic.EmptySynchronizedStatement": "warn",
    "basic.EmptyStaticInitializer": "warn",
    "basic.EmptyTryBlock": "error",
    "basic.EmptyWhileStatement": "warn",
    "basic.EmptyInstanceInitializer": "warn",
    "basic.EmptyMethod": "warn",
    "basic.EqualsAndHashCode": "error",
    "basic.EqualsOverloaded": "error",
    "basic.ExplicitGarbageCollection": "warn",
    "basic.ForLoopShouldBeWhileLoop": "warn",
    "basic.HardCodedWindowsFileSeparator": "warn",
    "basic.HardCodedWindowsRootDirectory": "warn",
    "basic.IntegerGetInteger": "warn",
    "basic.MultipleUnaryOperators": "warn",
    "basic.RandomDoubleCoercedToZero": "error",
    "basic.RemoveAllOnSelf": "error",
    "basic.ReturnFromFinallyBlock": "error",
    "basic.ThrowExceptionFromFinallyBlock": "error",
    "basic.ParameterAssignmentInFilterClosure": "warn"
  }
}